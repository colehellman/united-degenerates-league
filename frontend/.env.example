# Backend API URL — REQUIRED for production builds.
# Vite embeds this at build time into the JS bundle.
# If not set, defaults to http://localhost:8000 (only works locally).
#
# Local development:
VITE_API_URL=http://localhost:8000
#
# Render production (use your actual backend URL):
# VITE_API_URL=https://udl-api.onrender.com
